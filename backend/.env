# Email (Gmail) — for Trainer/Admin OTP password reset.
# EMAIL_PASS MUST be a 16-char Gmail App Password (2FA enabled), NOT your normal password.
# Generate at: myaccount.google.com > Security > 2-Step Verification > App passwords
EMAIL_USER=your-gmail@gmail.com
EMAIL_PASS=your-16-char-app-password

# SMS (MSG91 v5) — for Student phone OTP.
# SMS_API_KEY    = your MSG91 authkey
# SMS_TEMPLATE_ID = a DLT-approved OTP template id (created in the MSG91 dashboard;
#                   the template must contain an OTP variable ##OTP##).
# If either is left as a placeholder, the OTP is logged to the server console instead
# of being sent (dev fallback) — check the backend terminal for "[SMS-DEV] OTP for ...".
SMS_API_KEY=your-msg91-auth-key
SMS_TEMPLATE_ID=your-msg91-template-id
SMS_SENDER_ID=ROBQIZ