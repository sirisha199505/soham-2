# Leave VITE_API_URL empty in development — Vite proxy handles /api/* → http://localhost:3001
# In production, set this to your deployed API base URL (e.g. https://your-api.onrender.com)
VITE_API_URL=

# Google OAuth Client ID — get from Google Cloud Console → APIs & Services → Credentials
# Leave empty to disable Google Sign-In buttons
VITE_GOOGLE_CLIENT_ID=
